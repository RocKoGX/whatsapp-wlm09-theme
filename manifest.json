{
  "manifest_version": 3,
  "name": "WhatsApp Live Messenger ULTIMATE",
  "version": "1.4.2",
  "description": "Tema completo de Windows Live Messenger para WhatsApp Web. Incluye colores, banners y fondos de pantalla personalizados",

  "icons": {
    "48": "icons/icon.png"
  },

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": [
        "content/drag-windows.js",
        "content/style-injector.js",
        "content/icon-replacer.js",
        "content/ad-banner.js",
        "content/main.js"
      ]
    }
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "styles/wlm-theme.css",
        "assets/icons/*.png",
        "assets/icons/*.gif",
        "assets/icons/*.jpg",
        "assets/scenes/*",
        "assets/ads/*",
        "background/*",
        "background/*.jpg",
        "background/*.gif"
      ],
      "matches": ["https://web.whatsapp.com/*", "<all_urls>"]
    }
  ]
}
