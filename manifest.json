{
  "manifest_version": 3,
  "name": "WhatsApp Live Messenger ULTIMATE",
  "version": "1.5.1",
  "description": "Tema completo de Windows Live Messenger para WhatsApp Web. Incluye colores, banners y fondos de pantalla personalizados",

  "icons": {
    "48": "icons/icon.png"
  },

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": [
        "content/drag-windows.js",
        "content/style-injector.js",
        "content/icon-replacer.js",
        "content/ad-banner.js",
        "content/main.js",
        "content/sound-injector.js"
      ]
    }
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "manifest-assets.json",
        "styles/wlm-theme.css",
        "assets/icons/*.png",
        "assets/icons/*.gif",
        "assets/icons/*.jpg",
        "assets/icons/chat/*",
        "assets/icons/menu/*",
        "assets/icons/emoticons/*",
        "assets/icons/frames/*",
        "assets/icons/W7Icons/*",
        "assets/icons/scrollbar/*",
        "assets/icons/titlebar/*",
        "assets/scenes/default/*",
        "assets/scenes/aerochat-scenes/*",
        "assets/scenes/lol-scenes/*",
        "assets/scenes/custom/*",
        "assets/ads/aerochat/*",
        "assets/ads/bannerdepot/*",
        "assets/ads/default/*",
        "assets/ads/other/*",
        "assets/ads/custom/*",
        "background/default/*",
        "background/windows-7/*",
        "background/windows-vista/*",
        "background/windows-xp/*",
        "background/custom/*",
        "assets/sounds/*",
        "content/sound-modifier.js",
        "content/wlm-notification-injector.js",
        "content/wlm-focus-notifications.js"
      ],
      "matches": ["https://web.whatsapp.com/*", "<all_urls>"]
    }
  ]
}
